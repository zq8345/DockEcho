/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://models.dockecho.com; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# The self-hosted ort-wasm backend must be served with correct MIME: with the
# global nosniff above, the browser refuses to import the .mjs loader as a module
# (and to stream the .wasm) unless the Content-Type is explicit.
/vendor/transformers/wasm/ort-wasm-simd-threaded.jsep.mjs
  Content-Type: text/javascript; charset=utf-8
/vendor/transformers/wasm/ort-wasm-simd-threaded.jsep.wasm
  Content-Type: application/wasm

# CSP notes (Round 5c): 'wasm-unsafe-eval' is required by the ort-wasm backend —
# do NOT widen to 'unsafe-eval'. connect-src pins the single external origin: our
# own model host models.dockecho.com (runtime + wasm are same-origin under
# /vendor/). 'unsafe-inline' in style-src covers inline style attributes; JSON-LD
# (application/ld+json) is data, not script, so script-src 'self' is unaffected.
